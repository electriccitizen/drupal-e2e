{
  "name": "drupal-e2e",
  "version": "0.1.0",
  "description": "Generate Playwright E2E tests from Drupal config YAML",
  "type": "module",
  "bin": {
    "drupal-e2e": "dist/cli.js"
  },
  "files": [
    "dist/",
    "framework/"
  ],
  "scripts": {
    "build": "tsc && chmod +x dist/cli.js",
    "prepare": "npm run build"
  },
  "dependencies": {
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.0.0",
    "typescript": "^5.3.0"
  },
  "engines": {
    "node": ">=18"
  }
}
